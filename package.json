{
  "name": "lm-app",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx index.ts",
    "platform:api": "tsx index.ts",
    "platform:web:dev": "npm run dev --prefix web",
    "platform:web:build": "npm run build --prefix web",
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm run platform:api\" \"wait-on tcp:127.0.0.1:3850 && npm run platform:web:dev\""
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.3",
    "date-fns": "^4.1.0",
    "fastify": "^5.1.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
