# Local dev: copy this file to `.env` in this same folder:
#   cp .env.example .env   (Unix)
#   Copy-Item .env.example .env   (PowerShell)
#
# Optional overrides (see platform/index.ts for defaults):
# PLATFORM_PORT=3850
# PLATFORM_DB_PATH=
# PLATFORM_UPDATES_DIR=
# AMAAN_ROLLING_SYNC_MAX_MS=
#
# LM dashboard auth (see platform/http/platform-admin-auth.ts):
# PLATFORM_ADMIN_PASSWORD=   # set to require login for /api/platform/admin/*
# PLATFORM_JWT_SECRET=         # optional; ≥16 chars to pin JWT signing key (else derived from password)
