# Copy to the server (e.g. /etc/lm-app/lm-app.env) and reference from systemd EnvironmentFile=.

# Rolling license check-in window (ms). Clamped 1s–366d by the platform process.
# Default in code is 5d if unset. Uncomment to use e.g. 30 days = 2592000000
# AMAAN_ROLLING_SYNC_MAX_MS=2592000000

# Optional — defaults shown in platform/index.ts
# PLATFORM_PORT=3850
# PLATFORM_DB_PATH=/var/lib/lm-app/platform.db
# PLATFORM_UPDATES_DIR=/var/lib/lm-app/updates
